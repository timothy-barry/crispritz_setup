library(Biostrings)
source("~/.Rprofile")
fa_file <- paste0(.get_config_path("REF_GENOME_DIR"), "hg38_main_chroms.fa")
out_file <- paste0(.get_config_path("REF_GENOME_DIR"), "hg38_N_runs_min10.bed")
fa <- readDNAStringSet(fa_file)
con <- file(out_file, "w")
chr <- "chrY"
x <- toupper(as.character(fa[[chr]]))
class(x)
length(x)
nchar(x)
substr(x, 1, 10)
?gregexpr
hits <- gregexpr("N+", x)[[1]]
class(hits)
length(hits)
hits
if (hits[1] == -1) next
widths <- attr(hits, "match.length")
widths
keep <- widths >= 10
if (!any(keep)) next
starts <- hits[keep]
keep
ends <- starts + widths[keep] - 1
starts
ends
bed <- data.frame(chr, starts - 1, ends, "N_run", 0, "+")
bed
bed <- data.frame(chr = chr, start = starts - 1, end = ends, name = "N_run", score = 0, strand = "+")
bed
hits
substr(x, 44822, 44822+10)
substr(x, 44822, 44822+100)
substr(x, 222990, 222990+10)
